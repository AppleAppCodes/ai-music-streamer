{
  "expo": {
    "name": "Yoriax",
    "slug": "yoriax",
    "scheme": "yoriax",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#050505",
    "ios": {
      "bundleIdentifier": "com.yoriax.app",
      "buildNumber": "180",
      "usesAppleSignIn": true,
      "supportsTablet": false,
      "associatedDomains": [
        "applinks:www.yoriax.com",
        "applinks:yoriax.com"
      ],
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true,
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryAddUsageDescription": "YORIAX saves images only when you explicitly choose to do so.",
        "NSPhotoLibraryUsageDescription": "YORIAX uses your photo library so you can choose a profile picture.",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "package": "com.yoriax.app",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#050505"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "www.yoriax.com"
            },
            {
              "scheme": "https",
              "host": "yoriax.com"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-audio",
      [
        "expo-image-picker",
        {
          "photosPermission": "YORIAX uses your photo library so you can choose a profile picture."
        }
      ],
      "expo-status-bar",
      "expo-font",
      "expo-asset",
      [
        "expo-localization",
        {
          "supportedLocales": {
            "ios": [
              "de",
              "en",
              "es",
              "fr",
              "it",
              "pt",
              "nl"
            ],
            "android": [
              "de",
              "en",
              "es",
              "fr",
              "it",
              "pt",
              "nl"
            ]
          }
        }
      ],
      "expo-image"
    ],
    "extra": {
      "yoriaxReleaseStage": "production",
      "eas": {
        "projectId": "ca24776f-fea9-45f2-9d23-1dc5e26aed06"
      }
    }
  }
}
