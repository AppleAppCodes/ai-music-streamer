{
  "name": "@yoriax/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "start:dev-client:tunnel": "expo start --dev-client --tunnel",
    "start:go": "expo start --go",
    "start:tunnel": "expo start --tunnel",
    "android": "expo run:android",
    "android:device": "expo run:android --device",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "prebuild": "expo prebuild",
    "typecheck": "tsc --noEmit",
    "eas:preview:android": "eas build --platform android --profile preview",
    "eas:preview:ios": "eas build --platform ios --profile preview",
    "eas:production:android": "eas build --platform android --profile production",
    "eas:production:ios": "eas build --platform ios --profile production",
    "eas:submit:android": "eas submit --platform android --profile production",
    "eas:submit:ios": "eas submit --platform ios --profile production",
    "testflight": "eas build --platform ios --profile production --auto-submit",
    "playstore": "eas build --platform android --profile production --auto-submit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.2.0",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "@supabase/supabase-js": "2.107.0",
    "expo": "~56.0.12",
    "expo-apple-authentication": "~56.0.4",
    "expo-application": "~56.0.3",
    "expo-asset": "~56.0.17",
    "expo-audio": "~56.0.12",
    "expo-auth-session": "~56.0.14",
    "expo-blur": "~56.0.3",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.20",
    "expo-font": "~56.0.7",
    "expo-image": "~56.0.11",
    "expo-image-picker": "~56.0.18",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-localization": "~56.0.6",
    "expo-status-bar": "~56.0.4",
    "expo-web-browser": "^56.0.5",
    "i18n-js": "^4.5.3",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-url-polyfill": "3.0.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3",
    "yoriax-decorative-video": "file:modules/yoriax-decorative-video",
    "yoriax-remote-commands": "file:modules/yoriax-remote-commands"
  },
  "devDependencies": {
    "@types/react": "19.2.16",
    "typescript": "~6.0.3"
  }
}
