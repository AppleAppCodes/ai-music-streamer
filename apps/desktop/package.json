{
  "name": "@yoriax/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "YORIAX desktop app for macOS and Windows.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && electron .",
    "start": "npm run dev",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:mac:arm64": "npm run build && electron-builder --mac --arm64",
    "dist:mac:x64": "npm run build && electron-builder --mac --x64",
    "dist:mac:universal": "npm run build && electron-builder --mac --universal",
    "dist:win": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.yoriax.desktop",
    "productName": "YORIAX",
    "artifactName": "YORIAX-${version}-${os}-${arch}.${ext}",
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.music",
      "icon": "assets/icon.icns",
      "minimumSystemVersion": "12.0",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3"
  }
}
