{
  "name": "ai-music-streamer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "mobile:start": "npm --prefix apps/mobile run start",
    "mobile:android": "npm --prefix apps/mobile run android",
    "mobile:ios": "npm --prefix apps/mobile run ios",
    "mobile:prebuild": "npm --prefix apps/mobile run prebuild",
    "mobile:prebuild:android": "npm --prefix apps/mobile run prebuild -- --platform android",
    "mobile:prebuild:ios": "npm --prefix apps/mobile run prebuild -- --platform ios",
    "mobile:typecheck": "npm --prefix apps/mobile run typecheck",
    "mobile:lint": "eslint apps/mobile/App.tsx apps/mobile/src --max-warnings=0",
    "mobile:check": "npm run mobile:typecheck && npm run mobile:lint",
    "mobile:eas:preview:android": "cd apps/mobile && npx eas-cli build --platform android --profile preview",
    "mobile:eas:preview:ios": "cd apps/mobile && npx eas-cli build --platform ios --profile preview"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.5.2",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "browser-image-compression": "^2.0.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-fast-marquee": "^1.6.5",
    "react-i18next": "^17.0.8",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
